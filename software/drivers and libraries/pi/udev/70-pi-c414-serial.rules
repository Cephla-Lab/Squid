# Drop the FTDI VCP latency timer 16ms -> 1ms for the C-414's chatty GCS request/response
# traffic (MOV then an ONT? settle poll). At the 16ms default the timer, not the 115200 baud
# link, dominates per-command latency. Applies once 98-pi-c414-bind.rules has created the port.
ACTION=="add", SUBSYSTEM=="usb-serial", DRIVER=="ftdi_sio", ATTRS{idVendor}=="1a72", ATTRS{idProduct}=="102b", ATTR{latency_timer}="1"

# Grant access to the C-414's serial node without world-writable permissions: dialout group
# for the general case, plus TAG+="uaccess" so systemd-logind gives the locally seated user
# an ACL immediately -- Squid works right after setup, before the user has re-logged in to
# pick up the dialout membership. uaccess requires this file to sort before systemd's
# 73-seat-late.rules (which acts on the tag), hence the 70- prefix. The latency ATTR above
# lives on the usb-serial device; the /dev/ttyUSB* node itself is a "tty" device, so its
# permissions must be set by a tty-subsystem rule.
ACTION=="add", SUBSYSTEM=="tty", ATTRS{idVendor}=="1a72", ATTRS{idProduct}=="102b", GROUP="dialout", MODE="0660", TAG+="uaccess"
